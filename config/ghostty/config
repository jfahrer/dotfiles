# Default before the generated override exists.
theme = TokyoNight Night

# Make sure SSH works properly
shell-integration-features = ssh-terminfo,ssh-env,no-cursor

# Font
font-family = "JetBrains Mono"
# font-family = FiraCode Nerd Font Mono
font-size = 20

cursor-style = block
cursor-style-blink = false

# Optional override managed by the shared theme helper in ~/.config/ghostty/.
config-file = ?generated-theme

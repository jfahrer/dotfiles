{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/tmux-notify send \"Agent done\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/tmux-notify send \"Permissions requested\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
